# Required for Notion sync
NOTION_TOKEN=
DATABASE_ID=

# Optional multi-account config file for the main sync script
ACCOUNTS_FILE=accounts.json

# Optional single-account MT5 config for diagnostic tools in tools/
MT5_ACCOUNT=
MT5_PASSWORD=
MT5_SERVER=

# Optional mapping file. Relative paths are resolved from the repository root.
MAPPING_FILE=Claude.md

# Optional sync behavior
UPDATE_EXISTING=1
NOTION_VERSION=2022-06-28
NOTION_SYNC_DELAY_SECONDS=0.5
NOTION_HTTP_TIMEOUT_SECONDS=30
NOTION_HTTP_MAX_RETRIES=3
# Set to 0 to retry immediately without backoff.
NOTION_HTTP_RETRY_BACKOFF_SECONDS=1
SYNC_LOOKBACK_MINUTES=5
ACCOUNT_SWITCH_DELAY_SECONDS=2.5
SKIP_MAE_MFE=0

# Optional automation alerting and health-check thresholds
SYNC_ALERT_WEBHOOK_URL=
SYNC_HEALTH_STALE_MINUTES_INCREMENTAL=20
SYNC_HEALTH_STALE_MINUTES_RECONCILE=2160

# Optional sync window fallback. Used when an account has no history in Notion.
# Priority: SYNC_THIS_WEEK > SYNC_MONTHS > SYNC_DAYS > SYNC_HOURS
SYNC_HOURS=168
# SYNC_DAYS=7
# SYNC_MONTHS=3
# SYNC_THIS_WEEK=1
